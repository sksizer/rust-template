{
  "$schema_doc": "See scripts/cousin_review/task.md for the full schema. Each entry in 'cousins' describes a third-party repo that contains Rust code in explicitly whitelisted subpaths. Nothing is touched unless it is opted-in via 'targets[].applies' or 'global_applies'. 'forbidden_paths' is a belt-and-suspenders hard deny list. 'targets[].check' overrides the default check command for that subpath.",
  "$example": {
    "name": "acme-monorepo",
    "url": "git@github.com:acme/monorepo.git",
    "notes": "Bazel-based monorepo. CI is Bazel-managed — never touch .github or root configs.",
    "targets": [
      {
        "path": "backend/services/auth",
        "applies": ["rustfmt.toml", "clippy.toml"],
        "check": "bazel test //backend/services/auth/..."
      },
      {
        "path": "libs/core",
        "applies": ["rustfmt.toml"]
      }
    ],
    "global_applies": ["CLAUDE.md"],
    "forbidden_paths": [".github/**", "Cargo.toml", "justfile", "WORKSPACE", "MODULE.bazel"]
  },
  "cousins": [
    {
      "name": "template-tauri-nuxt",
      "url": "https://github.com/sksizer/template-tauri-nuxt",
      "notes": "Tauri + Nuxt template. Rust crate lives at src-tauri/. Root-level tooling (justfile, cliff.toml, .editorconfig, .prettierrc.yml, CLAUDE.md, scripts/, lefthook, commitlint, mise, release-it, Makefile) is owned by a different upstream (the Tauri template chain) — do NOT touch. Toolchain is pinned via mise.toml, not rust-toolchain.toml. Frontend is at src-nuxt/ and is entirely off-limits.",
      "targets": [
        {
          "path": "src-tauri",
          "applies": ["rustfmt.toml"],
          "check": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check"
        }
      ],
      "global_applies": [],
      "forbidden_paths": [
        ".github/**",
        "package.json",
        "pnpm-lock.yaml",
        "pnpm-workspace.yaml",
        "Makefile",
        "justfile",
        "cliff.toml",
        "lefthook.yml",
        "commitlint.config.ts",
        "mise.toml",
        ".release-it.json",
        ".editorconfig",
        ".prettierrc.yml",
        "CLAUDE.md",
        "scripts/**",
        "docs/**",
        "src-nuxt/**",
        "src-tauri/Cargo.toml",
        "src-tauri/Cargo.lock",
        "src-tauri/build.rs",
        "src-tauri/tauri.conf.json",
        "src-tauri/capabilities/**",
        "src-tauri/icons/**",
        "src-tauri/src/**"
      ]
    },
    {
      "name": "template-tauri-vue",
      "url": "https://github.com/sksizer/template-tauri-vue",
      "notes": "Tauri + Vue template. Rust crate at src-tauri/. Uses pnpm workspaces. Frontend at src-vue/. Root-level tooling owned by the Tauri template chain — do not touch. Toolchain via mise.toml.",
      "targets": [
        {
          "path": "src-tauri",
          "applies": ["rustfmt.toml"],
          "check": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check"
        }
      ],
      "global_applies": [],
      "forbidden_paths": [
        ".github/**",
