        "Makefile",
        "justfile",
        "cliff.toml",
        "lefthook.yml",
        "commitlint.config.ts",
        "mise.toml",
        ".release-it.json",
        ".editorconfig",
        ".prettierrc.yml",
        "CLAUDE.md",
        "scripts/**",
        ".scripts/**",
        "docs/**",
        "src-vue/**",
        "src-tauri/Cargo.toml",
        "src-tauri/build.rs",
        "src-tauri/tauri.conf.json",
        "src-tauri/capabilities/**",
        "src-tauri/icons/**",
        "src-tauri/src/**"
      ]
    },
    {
      "name": "template-tauri-vanillajs",
